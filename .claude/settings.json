{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project-Allowlist für Claude Code. Wird ins Repo eingecheckt und gilt für alle, die hier mit Claude Code arbeiten. Persönliche Overrides gehen in .claude/settings.local.json (gitignored).",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git diff)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git branch)",
      "Bash(git fetch:*)",
      "Bash(git fetch)",
      "Bash(git pull:*)",
      "Bash(git pull)",
      "Bash(git remote:*)",
      "Bash(git stash:*)",
      "Bash(git stash)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git commit -F:*)",
      "Bash(git commit -m:*)",
      "Bash(git push)",
      "Bash(git push origin:*)",
      "Bash(git restore:*)",
      "Bash(git rm:*)",
      "Bash(git check-ignore:*)",
      "Bash(git check-ignore)",
      "Bash(git ls-files:*)",
      "Bash(git ls-files)",
      "Bash(git blame:*)",
      "Bash(git tag:*)",
      "Bash(gh run:*)",
      "Bash(gh repo:*)",
      "Bash(gh pr:*)",
      "Bash(gh auth status)",
      "Bash(gh api:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git config:*)",
      "Bash(git checkout --:*)",
      "Bash(git rebase:*)"
    ]
  }
}
