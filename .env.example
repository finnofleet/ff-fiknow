# ============================================================
# Brand & Content
#
# Default (verstande.ch) Brand ist im Repo unter brand/brand.yaml und
# wird ins Docker-Image gebacken. Default-Content (Hauptrepo) ist NICHT
# im Image — wird lokal aus content/ gelesen oder via Brand-Build-Image
# darübergelegt.
#
# Pro abweichender Brand: kleiner Brand-Repo mit eigener brand.yaml und
# einem Dockerfile, das ghcr.io/<owner>/edu-platform:latest als Base
# nutzt und die Brand-Files überschreibt. Beispiel: yves-blaettler/fiknow-brand.
#
# Resultat: ein eigenes Image (ghcr.io/<owner>/<brand>:latest), das in
# Jelastic statt des edu-platform:latest gepullt wird.
#
# Doku: docs/BRAND-CONFIG.md
#
# Optional: BRAND_CONFIG_PATH überschreibt den Pfad zur brand.yaml
# (default: ./brand/brand.yaml).
# ============================================================

# ============================================================
# Auth — OIDC (Keycloak)
# ============================================================
#
# FIKNOW ist OIDC-only (Keycloak hinter Entra). Rolle = Keycloak (Source of
# Truth), gemappt aus den Token-Claims.

# Issuer = Keycloak-Realm-URL. In Prod ZWINGEND https.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Mapping Keycloak-Rolle/-Gruppe → App-Rolle. Nur „erhebende" Rollen nötig
# (alles andere = learner).
OIDC_ROLE_MAP=fiknow-curator:curator,fiknow-admin:admin
# Optional: Scopes (Default "openid profile email").
# OIDC_SCOPES=openid profile email
# Secret zum Signieren des Session-Cookies (min. 16 Zeichen). Fällt sonst auf
# PAYLOAD_SECRET zurück.
# OIDC_SESSION_SECRET=
# Session-Lebensdauer in Sekunden (Default 28800 = 8h).
# OIDC_SESSION_MAX_AGE_SEC=28800
# Öffentliche Basis-URL für die exakte redirect_uri. In Prod ZWINGEND setzen
# (wird nicht aus Request-Headern abgeleitet).
OIDC_REDIRECT_BASE=
# NUR LOKAL: erlaubt http-Issuer (Keycloak ohne TLS). In Prod NIE setzen.
# OIDC_ALLOW_INSECURE=false

# ============================================================
# Datenbank (Postgres)
# ============================================================

# Postgres-Connection (Drizzle-Migrationen + Queries).
# Beispiel: postgres://USER:PASS@HOST:5432/DB?sslmode=require
DATABASE_URL=

# ============================================================
# Payload CMS
# ============================================================

# Signiert Payload-eigene Sessions (interner JWT-Secret, getrennt vom GoTrue-Secret).
# Generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WICHTIG: in Production identisch über alle App-Container-Replikas, sonst
# invalidieren sich Editor-Sessions gegenseitig.
PAYLOAD_SECRET=

# Hinweis zur SSO-Bridge ins Payload-Admin (payload/auth/gotrue-strategy.ts):
# Die Strategy verifiziert das GoTrue-JWT NICHT lokal, sondern validiert es
# serverseitig gegen GoTrue selbst (GET ${SUPABASE_URL}/auth/v1/user mit dem
# Access-Token aus dem sb-*-Cookie). GoTrue validiert autoritativ — egal ob
# HS256 (Shared-Secret) oder asymmetrisch; der App-Container braucht KEIN
# JWT-Secret. Voraussetzungen:
#   - SUPABASE_URL muss vom App-Container SERVERSEITIG erreichbar sein und auf
#     das Kong-Gateway zeigen (Pfad /auth/v1/...). Prüfen:
#       curl -s -o /dev/null -w "%{http_code}\n" "$SUPABASE_URL/auth/v1/health"  → 200
#   - NEXT_PUBLIC_SUPABASE_ANON_KEY wird als apikey-Header mitgeschickt (Kong).
#   - Admin-Zugang nur für profiles.role IN (curator, editor, admin).

# ============================================================
# Bundle-Storage (Authoring Source-of-Truth, ADR 0001)
# ============================================================

# Verzeichnis, in dem hochgeladene Kurs-Bundles byte-treu als durable
# Source-of-Truth liegen (Payload/Postgres ist der daraus generierte Index).
# Layout: ${BUNDLE_STORAGE_DIR}/<slug>/<version>/<bundle-relativer-Pfad>
# In Production auf ein PERSISTENTES Volume zeigen lassen (Jelastic-Mount),
# sonst gehen Bundles bei Container-Redeploys verloren. Ohne Wert: Fallback
# auf .bundle-storage/ im Projekt-Root (nur Dev).
BUNDLE_STORAGE_DIR=

# Verzeichnis für hochgeladene Media-Dateien (Bilder). Default: public/media.
# Serving läuft über /api/media/file/<name> (Payload-Route), NICHT Next-Static
# /media/ — der Pfad ist also frei wählbar und nicht an /public gebunden.
# In Production auf ein PERSISTENTES, für die Container-UID (1001) beschreibbares
# Verzeichnis zeigen lassen, sonst gehen Bilder bei Redeploys verloren. Am
# einfachsten ein Unterordner des schon durablen Bundle-Storage-Volumes:
#   MEDIA_STORAGE_DIR=/app/bundle-storage/_media
# Dann braucht es KEINEN separaten Media-Mount und KEINEN chown.
MEDIA_STORAGE_DIR=

# ============================================================
# KI-Tutor (ADR 0002) — optional
#
# Der Tutor ist deploymentweit OPTIONAL. Fehlt LLM_API_KEY,
# ist nur der Tutor deaktiviert — Annotations/Notizen/Markierungen
# laufen ohne LLM weiter. Kein Fehler, kein Absturz.
#
# Für den FiKnow-Handover: eigenes Provider-Konto anlegen, Key
# hier eintragen — ein Env-Var-Tausch, kein Code-Change (analog
# zu Supabase/DB/Storage).
# ============================================================

# Provider-API-Key. PFLICHT für den Tutor — fehlt er, bleibt der Tutor AUS.
# Kein Default. Key beim Anbieter (Anthropic) anlegen:
# https://console.anthropic.com/settings/keys
LLM_API_KEY=

# LLM-Provider. Default: anthropic (einziger v1-Provider).
LLM_PROVIDER=anthropic

# API-Basis-URL. Default: https://api.anthropic.com
# Überschreibbar für einen EU-/CH-Region- + Zero-Data-Retention-Pfad
# (z. B. ein Anthropic-kompatibles Gateway / Proxy). User-Notizen und
# -Fragen sind persönliche Daten → bei Datenschutzbedarf ZDR-Pfad bevorzugen.
LLM_BASE_URL=https://api.anthropic.com

# Modell-ID. Default: claude-haiku-4-5 (günstigster Tier, für Basis-
# Erklärungen ausreichend). Ggf. auf claude-sonnet-4-6 hochstufen nach Messung.
LLM_MODEL=claude-haiku-4-5

# max_tokens-Cap pro Tutor-Antwort (Kosten-Hebel). Default: 1024.
LLM_MAX_TOKENS=1024

# ============================================================
# RAG-Index für den KI-Tutor (ADR 0003) — optional
#
# Embeddings für content-gegroundetes Retrieval. Ein EIGENES Konto/Key,
# getrennt vom LLM_API_KEY oben. Fehlt VOYAGE_API_KEY, ist nur die
# RAG-Indexierung aus — der Tutor läuft weiter (nicht-gegroundeter Pfad),
# Uploads laufen durch, Kurse bleiben „needs-reindex" bis ein Key da ist
# (dann: POST /api/authoring/reindex ohne slug = Backfill aller Kurse).
#
# Key anlegen: https://dashboard.voyageai.com → API Keys (Voyage gehört
# zu MongoDB; Free-Tier mit Gratis-Kontingent zum Starten).
# ============================================================

# Voyage-API-Key. Fehlt er → RAG-Indexierung AUS (kein Fehler). Kein Default.
VOYAGE_API_KEY=

# Embedding-Provider. Default: voyage (einziger v1-Provider).
EMBEDDING_PROVIDER=voyage

# Modell-ID. Default: voyage-3.5-lite (günstigster Tier, schlägt OpenAI-v3-large).
# Auf voyage-3.5 (höhere Qualität) hochstufbar OHNE DB-Migration — beide liefern
# 1024 Dimensionen, was das lesson_chunks-Schema festnagelt.
EMBEDDING_MODEL=voyage-3.5-lite

# API-Basis-URL. Default: https://api.voyageai.com (überschreibbar für Proxy).
EMBEDDING_BASE_URL=https://api.voyageai.com

# RAG-Retrieval-Schwelle (ADR 0003) — Rausch-Filter für die Kontext-Injektion:
# Kurs-Chunks mit Cosine-Score unter diesem Wert sind zu schwach und gehen NICHT
# in den Prompt. KEIN Scope-Router (gegroundet vs. Allgemeinwissen ist jetzt
# user-initiiert über den Button „Allgemeinwissen ergänzen"). Bleibt nichts
# übrig → Fallback auf die aktuelle Lektion. Default 0.4 (gültig: 0 < x < 1).
RAG_RELEVANCE_THRESHOLD=0.4

# MCP-Authoring-Server (PoC) — exponiert die Content-Management-Pipeline als
# Model-Context-Protocol-Tools unter POST /api/mcp/mcp (Streamable-HTTP), damit
# MCP-fähige Clients (Claude Desktop, Gruppen-Agents) Kurse anlegen/ändern/
# publishen. Aus, solange nicht explizit aktiviert. Auth = Authoring-Bearer-Token
# (cat_…, curator/admin) wie bei den anderen Authoring-Endpoints.
MCP_ENABLED=false

# Öffentliche Basis-URL der App, die das MCP-Tool request_asset_upload_url in die
# vor-signierte Asset-Upload-URL schreibt. NUR nötig, wenn der LB die Forwarding-
# Header (X-Forwarded-Host/-Proto) strippt/umschreibt — sonst wird die URL daraus
# automatisch abgeleitet. Ohne Schema-/Trailing-Slash-Eigenheiten, z. B.:
#   AUTHORING_PUBLIC_URL=https://app.fiknow.ch
AUTHORING_PUBLIC_URL=
